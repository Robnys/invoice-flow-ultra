# InvoiceFlow - Variables de Entorno
# Copia este archivo a .env.local y completa los valores

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Service Role Key (para uso en servidor - NO incluir en el cliente)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Opcional: Configuración de Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Opcional: Webhooks para integraciones
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Opcional: Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Opcional: Feature Flags
NEXT_PUBLIC_ENABLE_AI_FEATURES=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
